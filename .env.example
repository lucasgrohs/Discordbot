# ===== Discord =====
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-id
# Servidor onde os slash commands são registrados na hora (id do seu servidor).
DISCORD_GUILD_ID=

# ===== Banco de dados =====
# Em produção (docker compose) o DATABASE_URL é sobrescrito para apontar ao serviço "postgres".
DATABASE_URL=postgresql://shop:shop@localhost:5434/shopbot?schema=public

# ===== Servidor HTTP (endpoints da Kick) =====
# Porta interna do bot; em produção fica atrás do nginx (/kick/* -> esta porta).
WEBHOOK_PORT=8787

# ===== Sorteio por indicação =====
# Requer "Server Members Intent" no portal. 1 = ligado.
GIVEAWAY=0

# ===== Log de tickets (transcrição) =====
# Requer "Message Content Intent" no portal. 1 = ligado.
MESSAGE_LOG=0

# ===== Integração Kick -> VIP =====
# Sem KICK_CLIENT_ID a integração fica desligada (web server não sobe).
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
# URL pública do callback OAuth: <SEU_DOMINIO>/kick/callback
KICK_REDIRECT_URI=
KICK_SCOPES=user:read
# Validade fallback da sub (dias) quando o evento não traz expires_at.
KICK_SUB_DAYS=31
